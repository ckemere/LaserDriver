# ============================================================
# Laser Driver - MSPM0G3507 — arm-none-eabi-gcc build (Pi-native)
# ============================================================
# All required SDK files are vendored in-tree (see Makefile header).
# Only external dependency is the arm-none-eabi-gcc cross toolchain.
#
# Pi install:
#   sudo apt install gcc-arm-none-eabi
#   make -f Makefile.gcc

# Tools
CROSS           ?= arm-none-eabi
CC              := $(CROSS)-gcc
OBJCOPY         := $(CROSS)-objcopy
SIZE            := $(CROSS)-size

# Paths
PROJ_DIR        := .
BUILD_DIR       := $(PROJ_DIR)/build_gcc

# Source files
STARTUP_SRC     := $(PROJ_DIR)/startup/startup_mspm0g350x_gcc.c
STARTUP_OBJ     := $(BUILD_DIR)/startup_mspm0g350x_gcc.o
LINKER_SCRIPT   := $(PROJ_DIR)/linker/mspm0g3507.lds

OBJS            := $(BUILD_DIR)/main.o \
                   $(BUILD_DIR)/output_mux.o \
                   $(BUILD_DIR)/sysctl.o \
                   $(BUILD_DIR)/gpio.o \
                   $(BUILD_DIR)/pwm_timer.o \
                   $(BUILD_DIR)/tick_timers.o \
                   $(BUILD_DIR)/dac.o \
                   $(BUILD_DIR)/uart.o \
                   $(BUILD_DIR)/framing.o \
                   $(STARTUP_OBJ)

# Compiler flags
CPU_FLAGS       := -mcpu=cortex-m0plus -mthumb
OPT_FLAGS       := -Os -g3
WARN_FLAGS      := -Wall -Wextra -Wno-unused-parameter
DEAD_CODE       := -ffunction-sections -fdata-sections
INCLUDES        := -I$(PROJ_DIR)
CFLAGS          := $(CPU_FLAGS) $(OPT_FLAGS) $(WARN_FLAGS) $(DEAD_CODE) \
                   $(INCLUDES) -std=c11

# Linker
LFLAGS          := $(CPU_FLAGS) -T$(LINKER_SCRIPT) \
                   -Wl,-Map=$(BUILD_DIR)/main.map \
                   -Wl,--gc-sections \
                   --specs=nano.specs --specs=nosys.specs \
                   -nostartfiles

# Output
TARGET_ELF      := $(BUILD_DIR)/main.elf
TARGET_BIN      := $(BUILD_DIR)/main.bin
TARGET_HEX      := $(BUILD_DIR)/main.hex

# OpenOCD (Pi-side SWD flashing)
OPENOCD            ?= openocd
OPENOCD_INTERFACE  ?= openocd/pi-swd.cfg
OPENOCD_TARGET     ?= target/ti_mspm0.cfg
# Override on Pi 5: make flash OPENOCD_GPIOCHIP=4
OPENOCD_GPIOCHIP   ?= 0
OPENOCD_GPIO_ARGS  := \
    -c "adapter gpio swclk -chip $(OPENOCD_GPIOCHIP) 25" \
    -c "adapter gpio swdio -chip $(OPENOCD_GPIOCHIP) 24" \
    -c "adapter gpio srst  -chip $(OPENOCD_GPIOCHIP) 18"

# ============================================================

.PHONY: all clean size flash load burn reset

all: $(TARGET_ELF) $(TARGET_BIN) $(TARGET_HEX) size

size: $(TARGET_ELF)
	@$(SIZE) $<

$(TARGET_ELF): $(OBJS) | $(BUILD_DIR)
	$(CC) $(OBJS) $(LFLAGS) -o $@

$(TARGET_BIN): $(TARGET_ELF)
	$(OBJCOPY) -O binary $< $@

$(TARGET_HEX): $(TARGET_ELF)
	$(OBJCOPY) -O ihex $< $@

$(BUILD_DIR)/%.o: $(PROJ_DIR)/%.c | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(STARTUP_OBJ): $(STARTUP_SRC) | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

clean:
	rm -rf $(BUILD_DIR)

# Flash the freshly-built ELF to the MCU over SWD via OpenOCD.
# `load` and `burn` are aliases.
#
# Sequence: power_cycle.py brings the MCU up at fresh boot with PA19
# in its SWDIO default, the kernel UART driver is parked so it can't
# phantom-power the chip, and NRST is released.  OpenOCD then runs
# an explicit init / halt / flash write / reset sequence — rather
# than `program ... reset`, which triggers an automatic reset+halt
# inside init that we've observed timing out (the MCU is in the
# middle of the boot-blink busy-wait when the halt request arrives,
# and the subsequent reset's vector-catch isn't engaging).
#
# No verify step: the target-side CRC algorithm in ti_mspm0.cfg /
# OpenOCD 0.12.0+dev hangs the MCU, but the write itself is reliable.
# Visual confirmation of a successful flash is the ~4-second
# STIM_MIRROR boot blink right after this rule finishes.
flash load burn: $(TARGET_ELF) power_cycle
	$(OPENOCD) -f $(OPENOCD_INTERFACE) $(OPENOCD_GPIO_ARGS) \
	    -f $(OPENOCD_TARGET) \
	    -c "init" \
	    -c "halt" \
	    -c "flash write_image erase $(TARGET_ELF)" \
	    -c "reset run" \
	    -c "shutdown"

# Pulse Pi GPIO 23 (MCU_POWER_EN) LOW for 300 ms then HIGH.  Requires
# the Pi-side venv with gpiozero (see Pi/README.md).
.PHONY: power_cycle
power_cycle:
	@if [ -x $(HOME)/.venvs/laserhat/bin/python ]; then \
	    $(HOME)/.venvs/laserhat/bin/python ../Pi/power_cycle.py ; \
	else \
	    python3 ../Pi/power_cycle.py ; \
	fi

# Reset the MCU without changing what's in flash.
reset:
	$(OPENOCD) -f $(OPENOCD_INTERFACE) $(OPENOCD_GPIO_ARGS) \
	    -f $(OPENOCD_TARGET) \
	    -c "init; reset; exit"
