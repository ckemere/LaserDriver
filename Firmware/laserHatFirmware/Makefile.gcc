# ============================================================
# Laser Driver - MSPM0G3507 — arm-none-eabi-gcc build (Pi-native)
# ============================================================
# All required SDK files are vendored in-tree (see Makefile header).
# Only external dependency is the arm-none-eabi-gcc cross toolchain.
#
# Pi install:
#   sudo apt install gcc-arm-none-eabi
#   make -f Makefile.gcc

# Tools
CROSS           ?= arm-none-eabi
CC              := $(CROSS)-gcc
OBJCOPY         := $(CROSS)-objcopy
SIZE            := $(CROSS)-size

# Paths
PROJ_DIR        := .
BUILD_DIR       := $(PROJ_DIR)/build_gcc

# Source files
STARTUP_SRC     := $(PROJ_DIR)/startup/startup_mspm0g350x_gcc.c
STARTUP_OBJ     := $(BUILD_DIR)/startup_mspm0g350x_gcc.o
LINKER_SCRIPT   := $(PROJ_DIR)/linker/mspm0g3507.lds

OBJS            := $(BUILD_DIR)/laser_driver.o \
                   $(BUILD_DIR)/laser_pwm_control.o \
                   $(BUILD_DIR)/laser_sysctl.o \
                   $(BUILD_DIR)/laser_gpio.o \
                   $(BUILD_DIR)/laser_timera.o \
                   $(BUILD_DIR)/laser_timerg.o \
                   $(BUILD_DIR)/laser_dac.o \
                   $(BUILD_DIR)/laser_uart.o \
                   $(STARTUP_OBJ)

# Compiler flags
CPU_FLAGS       := -mcpu=cortex-m0plus -mthumb
OPT_FLAGS       := -Os -g3
WARN_FLAGS      := -Wall -Wextra -Wno-unused-parameter
DEAD_CODE       := -ffunction-sections -fdata-sections
INCLUDES        := -I$(PROJ_DIR)
CFLAGS          := $(CPU_FLAGS) $(OPT_FLAGS) $(WARN_FLAGS) $(DEAD_CODE) \
                   $(INCLUDES) -std=c11

# Linker
LFLAGS          := $(CPU_FLAGS) -T$(LINKER_SCRIPT) \
                   -Wl,-Map=$(BUILD_DIR)/laser_driver.map \
                   -Wl,--gc-sections \
                   --specs=nano.specs --specs=nosys.specs \
                   -nostartfiles

# Output
TARGET_ELF      := $(BUILD_DIR)/laser_driver.elf
TARGET_BIN      := $(BUILD_DIR)/laser_driver.bin
TARGET_HEX      := $(BUILD_DIR)/laser_driver.hex

# ============================================================

.PHONY: all clean size

all: $(TARGET_ELF) $(TARGET_BIN) $(TARGET_HEX) size

size: $(TARGET_ELF)
	@$(SIZE) $<

$(TARGET_ELF): $(OBJS) | $(BUILD_DIR)
	$(CC) $(OBJS) $(LFLAGS) -o $@

$(TARGET_BIN): $(TARGET_ELF)
	$(OBJCOPY) -O binary $< $@

$(TARGET_HEX): $(TARGET_ELF)
	$(OBJCOPY) -O ihex $< $@

$(BUILD_DIR)/%.o: $(PROJ_DIR)/%.c | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(STARTUP_OBJ): $(STARTUP_SRC) | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

clean:
	rm -rf $(BUILD_DIR)
