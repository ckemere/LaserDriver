	; ── Boost converter: MT3608, 5V→12V ───────────────────────────────────────
	; Vout = Vfb*(1 + R_FB1/R_FB2) = 0.6*(1 + 187k/10k) = 11.82V ≈ 12V
	; EN tied to VIN via R_EN (100k) — always on when 5V present
	(text "Boost Converter\n5V → 12V\nMT3608 (SOT-23-6)\nVout ≈ 11.8V\nR_FB1=187kΩ 1%\nR_FB2=10kΩ 1%\nL1=22µH\nD_BOOST=SS14"
		(at 20 25 0)
		(effects (font (size 1.0 1.0)) (justify left))
		(uuid "212bfd25-2000-0000-0000-000000000099")
	)
