	; ── Annotation labels ──────────────────────────────────────────────────────
	(text "Pi HAT — System Overview\nOrigin = top-left (GPIO back edge)\n\nGPIO pin assignments:\n  Pin  1 = 3V3 (MCU VCC via P-MOSFET)\n  Pin  2 = 5V  (boost + CH340N VBUS)\n  Pin  6 = GND\n  Pin 14 = GPIO17 → MOSFET gate (MSPM0 power-cycle)\n  Pin 18 = GPIO18 → TRIGGER (parallel with BNC)\n  Pin 24 = GPIO23 → SWCLK\n  Pin 26 = GPIO24 → SWDIO\n  Pin 22 = GPIO25 → NRST\n  Pin 28 = GPIO0  → EEPROM SDA (ID_SD)\n  Pin 27 = GPIO1  → EEPROM SCL (ID_SC)\n  Pin 32 = GPIO14 → MSPM0 UART TX\n  Pin 33 = GPIO15 → MSPM0 UART RX"
		(at 130 15 0)
		(effects (font (size 1.27 1.27)) (justify left))
		(uuid "212bfd25-0001-0000-0000-000000000001")
	)

